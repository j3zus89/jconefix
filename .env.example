# URL pública canónica (metadata, sitemap, emails, magic links). Sin barra final.
# Producción definitiva: https://jconefix.com.ar — configurar también en Vercel → Environment Variables.
# En Production NO uses https://jconefix.vercel.app: Google indexa esa URL y muestra el subdominio Vercel en resultados.
# NEXT_PUBLIC_SITE_URL=https://jconefix.com.ar
#
# SEO internacional (hreflang / canonical por host): dominio .com (Latinoamérica) y .com.ar (Argentina).
# Si no se definen, se usan https://jconefix.com y https://jconefix.com.ar.
# NEXT_PUBLIC_GLOBAL_SITE_URL=https://jconefix.com
# NEXT_PUBLIC_AR_SITE_URL=https://jconefix.com.ar
#
# Registro Premium + PayPal (/register/premium): cifrado del payload en cookie httpOnly.
# Recomendado en producción (32+ bytes aleatorios en base64). Si falta, se deriva de SERVICE_ROLE.
# PREMIUM_DIRECT_ENC_SECRET=

# Facebook Open Graph (evita advertencia "fb:app_id faltante" en depuradores de compartir).
# Crea/usa una app en Meta for Developers y pega aquí el App ID numérico.
# NEXT_PUBLIC_FACEBOOK_APP_ID=123456789012345

# Video promocional del hero (modal play). Opciones:
# - URL directa .mp4 (Supabase Storage, R2, Bunny…): no sube el archivo al deploy de Vercel.
# - Página de Vimeo (cualquier enlace tipo https://vimeo.com/123456789): el modal usa el reproductor embebido.
# NEXT_PUBLIC_HERO_VIDEO_URL=https://vimeo.com/1182393032
# NEXT_PUBLIC_HERO_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/tu-bucket/jconefix.mp4

# Número del canal de soporte (solo dígitos, prefijo país, sin +). No se muestra en la web.
# Tras "Enviar mensaje" en la landing se abre la app de mensajes del visitante con el texto listo.
# Ejemplo España: 34612345678
# Producción (Vercel): misma variable en Settings → Environment Variables → Production, luego redeploy.
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=34633286106

# PayPal — app «JC ONE FIX» (LatAm: pago manual /capture en USD). Sin Client ID el botón falla.
# Sandbox: usá el Client ID de la app en developers.paypal.com y el SECRET de la misma app.
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_ID=            # mismo Client ID que NEXT_PUBLIC (create-order / capture en servidor)
# PAYPAL_CLIENT_SECRET=        # nunca uses NEXT_PUBLIC_ para el secreto
# Obligatorio si mezclás entornos: sandbox vs live deben coincidir con NEXT_PUBLIC_PAYPAL_CLIENT_ID.
# Sandbox local / pruebas:
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# Producción (Vercel): si no definís PAYPAL_API_BASE, el código usa api-m.paypal.com automáticamente.
# Para forzar sandbox incluso con NODE_ENV=production (solo debugging):
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
#
# Suscripción PayPal España: en PayPal → Productos y planes → Plan ID (P-...).
# El checkout usa el botón "Suscribirse" cuando exista el ID del periodo elegido (mensual / anual).
# Plan mensual: P-0XY84943XD253743VNHH72ZY · anual: P-3RR9947292572903MNHH77NI (tus planes PayPal)
# NEXT_PUBLIC_PAYPAL_PLAN_ID_MENSUAL=P-0XY84943XD253743VNHH72ZY
# NEXT_PUBLIC_PAYPAL_PLAN_ID_ANUAL=P-3RR9947292572903MNHH77NI
# (Legacy, opcional) mismos valores si ya los tenías con otro nombre:
# NEXT_PUBLIC_PAYPAL_SUBSCRIPTION_PLAN_ES_MENSUAL=
# NEXT_PUBLIC_PAYPAL_SUBSCRIPTION_PLAN_ES_ANUAL=

# ── Pago Argentina (/checkout/ar) — solo Mercado Pago ──────────────────────
# Access Token de la aplicación (credenciales de producción o prueba). Servidor: nunca expongas al cliente.
# Webhook en MP: POST https://TU_DOMINIO/api/webhooks/mercadopago (tema "payment").
# MERCADOPAGO_ACCESS_TOKEN=
# URL pública (back_urls del checkout). En producción: https://jconefix.com.ar
# NEXT_PUBLIC_SITE_URL=https://jconefix.com.ar

# ── Notificaciones a clientes (Gmail SMTP) ───────────────────────────────────
# Correo oficial de soporte en la app y mailtos: soporte@jconefix.com.ar (constante en código).
# GMAIL_USER / GMAIL_APP_PASSWORD: cuenta desde la que Node envía por SMTP (puede ser otra cuenta si usás relay).
# No uses el mismo Gmail con el que entras al panel super admin.
# Contraseña de aplicación: myaccount.google.com/apppasswords (2FA obligatorio en esa cuenta)
# GMAIL_USER=tu-cuenta-de-envio@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
# Opcional: otro buzón para avisos internos (por defecto en código: soporte@jconefix.com.ar)
# ADMIN_ALERT_EMAIL=
# Opcional: remitente visible (si no pones nada, el From usa GMAIL_USER con nombre "JC ONE FIX")
# SMTP_FROM="JC ONE FIX <soporte@jconefix.com.ar>"

# ── ARCA / AFIP — variables de PLATAFORMA (no del taller) ─────────────────────
# Las definen UNA VEZ quien despliega JC ONE FIX (Vercel → Settings → Environment Variables).
# Podés hacerlo desde España u otro país: no hace falta estar en Argentina ni probar AFIP vos mismo.
# Los talleres argentinos solo suben .crt/.key y prueban desde el panel cuando esto ya está cargado.
#
# AFIP_SDK_ACCESS_TOKEN — Token de https://app.afipsdk.com (cuenta del producto / desarrollo).
# La librería @afipsdk/afip.js usa este token en el servidor; los clientes no lo ven.
# AFIP_SDK_ACCESS_TOKEN=
#
# ARCA_CREDENTIALS_MASTER_KEY — Clave para cifrar certificados en BD (32 bytes en Base64).
# Generar una vez: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ARCA_CREDENTIALS_MASTER_KEY=

# ── Soporte / bot: mensaje automático tipo «ya te atiende un humano» ─────────
# Por defecto se usa el perfil (foto + nombre) del email OWNER en super-admin-allowlist.
# Opcional: otro agente o UUID explícito (auth.users.id = profiles.id).
# SUPPORT_HANDOFF_AGENT_USER_ID=
# SUPPORT_HANDOFF_AGENT_EMAIL=
# SUPPORT_HANDOFF_DISPLAY_NAME=

# Ventana ms para considerar super admin “en línea” en transferencias de chat (default 90000). Máx. la de panel (3 min).
# SUPPORT_AGENT_ONLINE_WINDOW_MS=90000

# Bot soporte (Gemini): timeout ms (default 18000) y modelo si el principal devuelve 404.
# SUPPORT_BOT_GEMINI_TIMEOUT_MS=18000
# SUPPORT_BOT_GEMINI_MODEL=gemini-2.5-flash
# SUPPORT_BOT_GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# «Pulir con IA» (/api/improve-diagnosis): Groq (clave gsk_… en console.groq.com). Distinto del chat (GEMINI_API_KEY).
# GROQ_POLISH_API_KEY=
# GROQ_POLISH_MODEL=llama-3.3-70b-versatile
# GROQ_POLISH_FALLBACK_MODEL=llama-3.1-8b-instant
# Límites por usuario (tabla polish_gemini_calls; 0 = sin tope en ese eje). El chat usa SUPPORT_BOT_GEMINI_* aparte.
# POLISH_GEMINI_MAX_PER_USER_PER_HOUR=25
# POLISH_GEMINI_MAX_PER_USER_PER_DAY=100
# POLISH_GEMINI_MIN_INTERVAL_SEC=15
# Máx. pulsaciones de pulir por minuto en todo el panel (0 = sin tope). Requiere SUPABASE_SERVICE_ROLE_KEY + migración.
# POLISH_GEMINI_MAX_GLOBAL_PER_MINUTE=10

